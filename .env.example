# EsportsAdda backend — environment template
# Copy to `.env` for local development. On Render, set these in the dashboard.

# Port (Render injects its own — local default 5000)
PORT=5000

# "production" enables Secure / SameSite=None cookies. Required on Render.

# Mongo Atlas SRV string. Append `/esportsadda?retryWrites=true&w=majority`.
MONGO_URL=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/esportsadda?retryWrites=true&w=majority

# 64-byte hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Required — no fallback. The app will fail to sign/verify tokens if unset.
JWT_SECRET=replace_with_64_hex

# Brevo HTTP API (port 443 — works on Render, which blocks SMTP).
# Get the key from Brevo dashboard → SMTP & API → API Keys.
# EMAIL_FROM must be a verified sender in Brevo (Senders & Domains) — a plain
# Gmail address works once verified; no domain ownership required.
BREVO_API_KEY=xkeysib-your_api_key
EMAIL_FROM=verified-sender@example.com
EMAIL_FROM_NAME=Esports Adda

# Public URL of the deployed frontend. Used in verification email links.
FRONTEND_URL=https://your-app.vercel.app

# Comma-separated allow-list for CORS + Socket.io.
# Must include EVERY origin the browser hits the API from (no trailing slash).
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

